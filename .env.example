# 化粧品宣稱檢核助手 — 環境變數範本
# 複製為 .env 並填入實際值（.env 不得 commit）

# ── Telegram Bot ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=put_your_bot_token_here
# 只允許的 user_id（Kenji 本人），多個用逗號分隔
ALLOWED_USER_IDS=

# ── Claude API ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── 部署（Phase 3 才會用到）──────────────────────────────────
FLY_APP_NAME=cosmetic-claim-checker
LOG_LEVEL=INFO
